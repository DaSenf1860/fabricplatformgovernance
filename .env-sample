# Environment Variables Configuration
# Copy this file to .env and update with your actual values

# ====================================
# Azure Fabric & Authentication
# ====================================

# Your Azure tenant ID (GUID format)
TENANT_ID=your-tenant-id-here

# Azure app registration client ID (GUID format)
CLIENT_ID=your-client-id-here

# Azure app registration object ID (GUID format)
CLIENT_OBJECT_ID=your-client-object-id-here

# Azure app registration client secret
CLIENT_SECRET=your-client-secret-here

# ====================================
# Database Configuration
# ====================================

# SQL Server hostname (Azure SQL Database or SQL Server)
# Example: yourserver.database.windows.net or yourserver.database.fabric.microsoft.com
DB_SERVER=your-database-server.database.fabric.microsoft.com

# Database name
# Example: fabricmanagement
DB_NAME=your-database-name

